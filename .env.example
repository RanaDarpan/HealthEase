# Environment Variables Template for MindEase
# Copy this file to .env and fill in your actual values

# MongoDB Connection
# Get your MongoDB connection string from MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mindease?retryWrites=true&w=majority

# NextAuth.js Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Encryption Key for sensitive data
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# OpenAI API Key (Primary — used for chatbot)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Override default models (defaults: gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_ANALYSIS_MODEL=gpt-4o-mini

# Groq API Key (Legacy fallback)
# Get your API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Node Environment
NODE_ENV=development
